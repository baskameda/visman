<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_VisitProcess2"
                  targetNamespace="http://bpmn.io/schema/bpmn"
                  exporter="Camunda Modeler"
                  exporterVersion="5.43.1">

  <!--
    VisitProcess_2.0 — Invitation / SecurityCheck / Visit flow
    ============================================================
    Started programmatically by InvitationController (no Invite user task).

    Process variables at start:
      starter      (String)    — inviter username
      invitationId (Long)      — poc_invitation.id
      visitorIds   (List<Long>)— one entry per visitor
      entranceId   (Long)      — poc_entrance.id

    Parallel multi-instance subprocess — one instance per visitorId.
    Per-instance local variables (set by delegates / task completion):
      visitorId              — injected by multi-instance framework
      currentSecurityCheckId — set by visitorBlacklistCheckDelegate
      blacklisted            — set by visitorBlacklistCheckDelegate
      securityDecision       — APPROVE | REFUSE | BLACKLIST | ASK_INVITER
      securityReviewer       — set on ASK_INVITER path
      clarificationCount     — incremented by script task (per instance local)
      clarificationQuestion  — set by security officer
      clarificationAnswer    — set by inviter
  -->

  <bpmn:process id="VisitProcess_2.0" name="Visit Process 2.0" isExecutable="true" camunda:versionTag="1">

    <!-- ── Start Event ──────────────────────────────────────────────────── -->
    <bpmn:startEvent id="StartEvent_v2" name="Start">
      <bpmn:outgoing>Flow_Start_Sub</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- ═══════════════════════════════════════════════════════════════════
         Parallel multi-instance subprocess — one token per visitor
         ═══════════════════════════════════════════════════════════════════ -->
    <bpmn:subProcess id="SubProcess_PerVisitor" name="Per Visitor Security Check">
      <bpmn:incoming>Flow_Start_Sub</bpmn:incoming>
      <bpmn:outgoing>Flow_Sub_End</bpmn:outgoing>

      <bpmn:multiInstanceLoopCharacteristics
          camunda:collection="${visitorIds}"
          camunda:elementVariable="visitorId">
      </bpmn:multiInstanceLoopCharacteristics>

      <!-- ── Subprocess Start ─────────────────────────────────────────── -->
      <bpmn:startEvent id="SubStart_v2">
        <bpmn:outgoing>Flow_Sub_Blacklist</bpmn:outgoing>
      </bpmn:startEvent>

      <!-- ── Service Task: Blacklist Check ───────────────────────────── -->
      <!--
        Sets local: blacklisted (boolean), currentSecurityCheckId (Long)
      -->
      <bpmn:serviceTask id="ST_BlacklistCheck" name="Blacklist Check"
                        camunda:delegateExpression="${visitorBlacklistCheckDelegate}">
        <bpmn:incoming>Flow_Sub_Blacklist</bpmn:incoming>
        <bpmn:outgoing>Flow_Blacklist_GW</bpmn:outgoing>
      </bpmn:serviceTask>

      <!-- ── Gateway: Blacklisted? ────────────────────────────────────── -->
      <bpmn:exclusiveGateway id="GW_Blacklisted" name="Blacklisted?">
        <bpmn:incoming>Flow_Blacklist_GW</bpmn:incoming>
        <bpmn:outgoing>Flow_IsBlacklisted</bpmn:outgoing>
        <bpmn:outgoing>Flow_NotBlacklisted</bpmn:outgoing>
      </bpmn:exclusiveGateway>

      <!-- ── Service Task: Handle Pre-Blacklisted Visitor ────────────── -->
      <!--
        Marks the SecurityCheck as REFUSED (visitor already blacklisted).
        securityDecision is null here → delegate defaults to REFUSED status.
      -->
      <bpmn:serviceTask id="ST_HandleBlacklisted" name="Handle Blacklisted"
                        camunda:delegateExpression="${securityCheckRefusalDelegate}">
        <bpmn:incoming>Flow_IsBlacklisted</bpmn:incoming>
        <bpmn:outgoing>Flow_Blk_SubEnd</bpmn:outgoing>
      </bpmn:serviceTask>

      <!-- ── Subprocess End: Visitor was pre-blacklisted ─────────────── -->
      <bpmn:endEvent id="SubEnd_Blacklisted" name="Visitor Pre-Blacklisted">
        <bpmn:incoming>Flow_Blk_SubEnd</bpmn:incoming>
      </bpmn:endEvent>

      <!-- ── User Task: Security Check ───────────────────────────────── -->
      <!--
        Task listener (CREATE):
          - Exposes securityCheckId as task-local variable for the frontend
          - Re-assigns to securityReviewer when looping back after clarification
        Candidate group: Security
        Completed by SecurityCheckController.decide() via taskService.complete()
      -->
      <bpmn:userTask id="Activity_SecurityCheck_V2" name="Security Check"
                     camunda:candidateGroups="Security">
        <bpmn:extensionElements>
          <camunda:taskListener event="create"
                                delegateExpression="${securityCheckTaskListener}" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_NotBlacklisted</bpmn:incoming>
        <bpmn:incoming>Flow_ClarDone_V2</bpmn:incoming>
        <bpmn:outgoing>Flow_SecCheck_GW</bpmn:outgoing>
      </bpmn:userTask>

      <!-- ── Gateway: Security Decision ──────────────────────────────── -->
      <bpmn:exclusiveGateway id="GW_SecurityDecision" name="Security Decision">
        <bpmn:incoming>Flow_SecCheck_GW</bpmn:incoming>
        <bpmn:outgoing>Flow_Approve</bpmn:outgoing>
        <bpmn:outgoing>Flow_Refuse</bpmn:outgoing>
        <bpmn:outgoing>Flow_AskInviter_V2</bpmn:outgoing>
      </bpmn:exclusiveGateway>

      <!-- ── Service Task: Create Visits (APPROVE path) ──────────────── -->
      <!--
        Marks SecurityCheck as APPROVED and creates one poc_visit per day.
        Reads: currentSecurityCheckId, visitorId (local), invitationId, entranceId (process)
      -->
      <bpmn:serviceTask id="ST_VisitCreation" name="Create Visits"
                        camunda:delegateExpression="${visitCreationDelegate}">
        <bpmn:incoming>Flow_Approve</bpmn:incoming>
        <bpmn:outgoing>Flow_VisitCreation_SubEnd</bpmn:outgoing>
      </bpmn:serviceTask>

      <!-- ── Subprocess End: Visitor Approved ────────────────────────── -->
      <bpmn:endEvent id="SubEnd_Approved" name="Visitor Approved">
        <bpmn:incoming>Flow_VisitCreation_SubEnd</bpmn:incoming>
      </bpmn:endEvent>

      <!-- ── Service Task: Handle Refusal (REFUSE / BLACKLIST path) ──── -->
      <!--
        Reads securityDecision:
          REFUSE    → status = REFUSED
          BLACKLIST → status = BLACKLISTED, also sets poc_visitor.blacklisted = true
      -->
      <bpmn:serviceTask id="ST_HandleRefusal" name="Handle Refusal"
                        camunda:delegateExpression="${securityCheckRefusalDelegate}">
        <bpmn:incoming>Flow_Refuse</bpmn:incoming>
        <bpmn:outgoing>Flow_Refusal_SubEnd</bpmn:outgoing>
      </bpmn:serviceTask>

      <!-- ── Subprocess End: Visitor Refused ─────────────────────────── -->
      <bpmn:endEvent id="SubEnd_Refused" name="Visitor Refused">
        <bpmn:incoming>Flow_Refusal_SubEnd</bpmn:incoming>
      </bpmn:endEvent>

      <!-- ── Script Task: Increment Clarification Count ──────────────── -->
      <!--
        Uses setVariableLocal so the count is scoped to this subprocess instance.
        All tasks in a sequential subprocess share the same execution, so the
        local variable persists until the subprocess instance ends.
      -->
      <bpmn:scriptTask id="ST_IncrCount" name="Increment Count" scriptFormat="groovy">
        <bpmn:incoming>Flow_AskInviter_V2</bpmn:incoming>
        <bpmn:outgoing>Flow_IncrCount_GW</bpmn:outgoing>
        <bpmn:script>def c = execution.getVariableLocal('clarificationCount')
execution.setVariableLocal('clarificationCount', c == null ? 1L : (c as Long) + 1L)</bpmn:script>
      </bpmn:scriptTask>

      <!-- ── Gateway: Max Clarifications Reached? ─────────────────────── -->
      <bpmn:exclusiveGateway id="GW_MaxLoops" name="Max Loops?">
        <bpmn:incoming>Flow_IncrCount_GW</bpmn:incoming>
        <bpmn:outgoing>Flow_MaxLoops_V2</bpmn:outgoing>
        <bpmn:outgoing>Flow_NeedsClarif_V2</bpmn:outgoing>
      </bpmn:exclusiveGateway>

      <!-- ── Service Task: Auto Refuse (max loops reached) ────────────── -->
      <!--
        securityDecision is still "ASK_INVITER" at this point →
        delegate defaults to REFUSED status (not BLACKLISTED).
      -->
      <bpmn:serviceTask id="ST_AutoRefuse" name="Auto Refuse"
                        camunda:delegateExpression="${securityCheckRefusalDelegate}">
        <bpmn:incoming>Flow_MaxLoops_V2</bpmn:incoming>
        <bpmn:outgoing>Flow_AutoRefuse_SubEnd</bpmn:outgoing>
      </bpmn:serviceTask>

      <!-- ── Subprocess End: Auto Refused ────────────────────────────── -->
      <bpmn:endEvent id="SubEnd_AutoRefused" name="Auto Refused">
        <bpmn:incoming>Flow_AutoRefuse_SubEnd</bpmn:incoming>
      </bpmn:endEvent>

      <!-- ── User Task: Provide Clarification ─────────────────────────── -->
      <!--
        Assigned to the original inviter (starter).
        Task listener (CREATE): exposes securityCheckId as task-local variable.
        Completed by SecurityCheckController.clarify() via taskService.complete()
      -->
      <bpmn:userTask id="Activity_Clarification_V2" name="Provide Clarification"
                     camunda:assignee="${starter}">
        <bpmn:extensionElements>
          <camunda:taskListener event="create"
                                delegateExpression="${securityCheckTaskListener}" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_NeedsClarif_V2</bpmn:incoming>
        <bpmn:outgoing>Flow_ClarDone_V2</bpmn:outgoing>
      </bpmn:userTask>

      <!-- ══ Subprocess Sequence Flows ════════════════════════════════ -->

      <bpmn:sequenceFlow id="Flow_Sub_Blacklist"       sourceRef="SubStart_v2"              targetRef="ST_BlacklistCheck" />
      <bpmn:sequenceFlow id="Flow_Blacklist_GW"        sourceRef="ST_BlacklistCheck"         targetRef="GW_Blacklisted" />

      <bpmn:sequenceFlow id="Flow_IsBlacklisted"       sourceRef="GW_Blacklisted"            targetRef="ST_HandleBlacklisted">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${blacklisted == true}</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="Flow_NotBlacklisted"      sourceRef="GW_Blacklisted"            targetRef="Activity_SecurityCheck_V2">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${blacklisted != true}</bpmn:conditionExpression>
      </bpmn:sequenceFlow>

      <bpmn:sequenceFlow id="Flow_Blk_SubEnd"          sourceRef="ST_HandleBlacklisted"      targetRef="SubEnd_Blacklisted" />
      <bpmn:sequenceFlow id="Flow_SecCheck_GW"         sourceRef="Activity_SecurityCheck_V2" targetRef="GW_SecurityDecision" />

      <bpmn:sequenceFlow id="Flow_Approve"             sourceRef="GW_SecurityDecision"       targetRef="ST_VisitCreation">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${securityDecision == 'APPROVE'}</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="Flow_Refuse"              sourceRef="GW_SecurityDecision"       targetRef="ST_HandleRefusal">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${securityDecision == 'REFUSE' || securityDecision == 'BLACKLIST'}</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="Flow_AskInviter_V2"       sourceRef="GW_SecurityDecision"       targetRef="ST_IncrCount">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${securityDecision == 'ASK_INVITER'}</bpmn:conditionExpression>
      </bpmn:sequenceFlow>

      <bpmn:sequenceFlow id="Flow_VisitCreation_SubEnd" sourceRef="ST_VisitCreation"         targetRef="SubEnd_Approved" />
      <bpmn:sequenceFlow id="Flow_Refusal_SubEnd"       sourceRef="ST_HandleRefusal"         targetRef="SubEnd_Refused" />

      <bpmn:sequenceFlow id="Flow_IncrCount_GW"        sourceRef="ST_IncrCount"              targetRef="GW_MaxLoops" />

      <bpmn:sequenceFlow id="Flow_MaxLoops_V2"         sourceRef="GW_MaxLoops"               targetRef="ST_AutoRefuse">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${clarificationCount >= 5}</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="Flow_NeedsClarif_V2"      sourceRef="GW_MaxLoops"               targetRef="Activity_Clarification_V2">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${clarificationCount &lt; 5}</bpmn:conditionExpression>
      </bpmn:sequenceFlow>

      <bpmn:sequenceFlow id="Flow_AutoRefuse_SubEnd"   sourceRef="ST_AutoRefuse"             targetRef="SubEnd_AutoRefused" />
      <bpmn:sequenceFlow id="Flow_ClarDone_V2"         sourceRef="Activity_Clarification_V2" targetRef="Activity_SecurityCheck_V2" />

    </bpmn:subProcess>

    <!-- ── Process End Event ────────────────────────────────────────────── -->
    <bpmn:endEvent id="EndEvent_v2" name="All Visitors Processed">
      <bpmn:incoming>Flow_Sub_End</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ── Process-level Sequence Flows ─────────────────────────────────── -->
    <bpmn:sequenceFlow id="Flow_Start_Sub" sourceRef="StartEvent_v2"      targetRef="SubProcess_PerVisitor" />
    <bpmn:sequenceFlow id="Flow_Sub_End"   sourceRef="SubProcess_PerVisitor" targetRef="EndEvent_v2" />

  </bpmn:process>

  <!-- ════ BPMN Diagram Layout ════════════════════════════════════════════ -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_v2">
    <bpmndi:BPMNPlane id="BPMNPlane_v2" bpmnElement="VisitProcess_2.0">

      <!-- Process-level shapes -->
      <bpmndi:BPMNShape id="StartEvent_v2_di" bpmnElement="StartEvent_v2">
        <dc:Bounds x="162" y="302" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="168" y="345" width="25" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="SubProcess_PerVisitor_di" bpmnElement="SubProcess_PerVisitor" isExpanded="true">
        <dc:Bounds x="250" y="100" width="1800" height="520" />
        <bpmndi:BPMNLabel><dc:Bounds x="870" y="106" width="160" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEvent_v2_di" bpmnElement="EndEvent_v2">
        <dc:Bounds x="2102" y="302" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="2076" y="345" width="88" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Subprocess interior shapes (absolute coordinates within subprocess bounds) -->

      <bpmndi:BPMNShape id="SubStart_v2_di" bpmnElement="SubStart_v2">
        <dc:Bounds x="312" y="302" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="ST_BlacklistCheck_di" bpmnElement="ST_BlacklistCheck">
        <dc:Bounds x="400" y="280" width="120" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GW_Blacklisted_di" bpmnElement="GW_Blacklisted" isMarkerVisible="true">
        <dc:Bounds x="585" y="295" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="572" y="352" width="77" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Blacklisted path (upward) -->
      <bpmndi:BPMNShape id="ST_HandleBlacklisted_di" bpmnElement="ST_HandleBlacklisted">
        <dc:Bounds x="550" y="150" width="120" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="SubEnd_Blacklisted_di" bpmnElement="SubEnd_Blacklisted">
        <dc:Bounds x="732" y="172" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="707" y="215" width="87" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Main path continues -->
      <bpmndi:BPMNShape id="Activity_SecurityCheck_V2_di" bpmnElement="Activity_SecurityCheck_V2">
        <dc:Bounds x="700" y="280" width="120" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GW_SecurityDecision_di" bpmnElement="GW_SecurityDecision" isMarkerVisible="true">
        <dc:Bounds x="895" y="295" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="870" y="352" width="100" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- APPROVE path (upward) -->
      <bpmndi:BPMNShape id="ST_VisitCreation_di" bpmnElement="ST_VisitCreation">
        <dc:Bounds x="1010" y="150" width="120" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="SubEnd_Approved_di" bpmnElement="SubEnd_Approved">
        <dc:Bounds x="1192" y="172" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1167" y="215" width="86" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- REFUSE path (downward) -->
      <bpmndi:BPMNShape id="ST_HandleRefusal_di" bpmnElement="ST_HandleRefusal">
        <dc:Bounds x="1010" y="440" width="120" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="SubEnd_Refused_di" bpmnElement="SubEnd_Refused">
        <dc:Bounds x="1192" y="462" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1170" y="505" width="80" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- ASK_INVITER path (continues right) -->
      <bpmndi:BPMNShape id="ST_IncrCount_di" bpmnElement="ST_IncrCount">
        <dc:Bounds x="1010" y="292" width="100" height="56" />
        <bpmndi:BPMNLabel><dc:Bounds x="1010" y="355" width="100" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="GW_MaxLoops_di" bpmnElement="GW_MaxLoops" isMarkerVisible="true">
        <dc:Bounds x="1175" y="295" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1162" y="352" width="76" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Auto-refuse path (downward from MaxLoops) -->
      <bpmndi:BPMNShape id="ST_AutoRefuse_di" bpmnElement="ST_AutoRefuse">
        <dc:Bounds x="1290" y="440" width="120" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="SubEnd_AutoRefused_di" bpmnElement="SubEnd_AutoRefused">
        <dc:Bounds x="1472" y="462" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1454" y="505" width="72" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Clarification path (continues right from MaxLoops) -->
      <bpmndi:BPMNShape id="Activity_Clarification_V2_di" bpmnElement="Activity_Clarification_V2">
        <dc:Bounds x="1290" y="280" width="120" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- ════ Edges ════════════════════════════════════════════════════ -->

      <!-- Process-level flows -->
      <bpmndi:BPMNEdge id="Flow_Start_Sub_di" bpmnElement="Flow_Start_Sub">
        <di:waypoint x="198" y="320" /><di:waypoint x="250" y="320" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_Sub_End_di" bpmnElement="Flow_Sub_End">
        <di:waypoint x="2050" y="320" /><di:waypoint x="2102" y="320" />
      </bpmndi:BPMNEdge>

      <!-- Subprocess internal flows -->
      <bpmndi:BPMNEdge id="Flow_Sub_Blacklist_di" bpmnElement="Flow_Sub_Blacklist">
        <di:waypoint x="348" y="320" /><di:waypoint x="400" y="320" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_Blacklist_GW_di" bpmnElement="Flow_Blacklist_GW">
        <di:waypoint x="520" y="320" /><di:waypoint x="585" y="320" />
      </bpmndi:BPMNEdge>

      <!-- Blacklisted = true → up to ST_HandleBlacklisted -->
      <bpmndi:BPMNEdge id="Flow_IsBlacklisted_di" bpmnElement="Flow_IsBlacklisted">
        <di:waypoint x="610" y="295" /><di:waypoint x="610" y="230" />
        <bpmndi:BPMNLabel><dc:Bounds x="616" y="258" width="40" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <!-- Blacklisted = false → SecurityCheck -->
      <bpmndi:BPMNEdge id="Flow_NotBlacklisted_di" bpmnElement="Flow_NotBlacklisted">
        <di:waypoint x="635" y="320" /><di:waypoint x="700" y="320" />
        <bpmndi:BPMNLabel><dc:Bounds x="645" y="302" width="46" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_Blk_SubEnd_di" bpmnElement="Flow_Blk_SubEnd">
        <di:waypoint x="670" y="190" /><di:waypoint x="732" y="190" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_SecCheck_GW_di" bpmnElement="Flow_SecCheck_GW">
        <di:waypoint x="820" y="320" /><di:waypoint x="895" y="320" />
      </bpmndi:BPMNEdge>

      <!-- APPROVE → up to VisitCreation -->
      <bpmndi:BPMNEdge id="Flow_Approve_di" bpmnElement="Flow_Approve">
        <di:waypoint x="920" y="295" /><di:waypoint x="920" y="190" /><di:waypoint x="1010" y="190" />
        <bpmndi:BPMNLabel><dc:Bounds x="927" y="238" width="46" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <!-- REFUSE / BLACKLIST → down to HandleRefusal -->
      <bpmndi:BPMNEdge id="Flow_Refuse_di" bpmnElement="Flow_Refuse">
        <di:waypoint x="920" y="345" /><di:waypoint x="920" y="480" /><di:waypoint x="1010" y="480" />
        <bpmndi:BPMNLabel><dc:Bounds x="927" y="408" width="41" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <!-- ASK_INVITER → IncrCount -->
      <bpmndi:BPMNEdge id="Flow_AskInviter_V2_di" bpmnElement="Flow_AskInviter_V2">
        <di:waypoint x="945" y="320" /><di:waypoint x="1010" y="320" />
        <bpmndi:BPMNLabel><dc:Bounds x="950" y="302" width="57" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_VisitCreation_SubEnd_di" bpmnElement="Flow_VisitCreation_SubEnd">
        <di:waypoint x="1130" y="190" /><di:waypoint x="1192" y="190" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_Refusal_SubEnd_di" bpmnElement="Flow_Refusal_SubEnd">
        <di:waypoint x="1130" y="480" /><di:waypoint x="1192" y="480" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_IncrCount_GW_di" bpmnElement="Flow_IncrCount_GW">
        <di:waypoint x="1110" y="320" /><di:waypoint x="1175" y="320" />
      </bpmndi:BPMNEdge>

      <!-- >= 5 → down to AutoRefuse -->
      <bpmndi:BPMNEdge id="Flow_MaxLoops_V2_di" bpmnElement="Flow_MaxLoops_V2">
        <di:waypoint x="1200" y="345" /><di:waypoint x="1200" y="480" /><di:waypoint x="1290" y="480" />
        <bpmndi:BPMNLabel><dc:Bounds x="1207" y="408" width="40" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <!-- < 5 → Clarification -->
      <bpmndi:BPMNEdge id="Flow_NeedsClarif_V2_di" bpmnElement="Flow_NeedsClarif_V2">
        <di:waypoint x="1225" y="320" /><di:waypoint x="1290" y="320" />
        <bpmndi:BPMNLabel><dc:Bounds x="1232" y="302" width="46" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_AutoRefuse_SubEnd_di" bpmnElement="Flow_AutoRefuse_SubEnd">
        <di:waypoint x="1410" y="480" /><di:waypoint x="1472" y="480" />
      </bpmndi:BPMNEdge>

      <!-- Clarification done → loop back to SecurityCheck (routing above all elements) -->
      <bpmndi:BPMNEdge id="Flow_ClarDone_V2_di" bpmnElement="Flow_ClarDone_V2">
        <di:waypoint x="1350" y="280" />
        <di:waypoint x="1350" y="130" />
        <di:waypoint x="760"  y="130" />
        <di:waypoint x="760"  y="280" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>
