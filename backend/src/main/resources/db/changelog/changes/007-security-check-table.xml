<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!-- One row per (invitation, visitor) pair — driven by the BPMN multi-instance subprocess -->
    <changeSet id="007-1" author="poc">
        <createTable tableName="poc_security_check">
            <column name="id"                     type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="invitation_id"          type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_sc_invitation"
                             references="poc_invitation(id)"/>
            </column>
            <column name="visitor_id"             type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_sc_visitor"
                             references="poc_visitor(id)"/>
            </column>
            <!-- PENDING | APPROVED | REFUSED | BLACKLISTED -->
            <column name="status"                 type="VARCHAR(20)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="reliability"            type="INT"/>
            <column name="security_note"          type="VARCHAR(2000)"/>
            <column name="security_reviewer"      type="VARCHAR(100)"/>
            <column name="clarification_question" type="VARCHAR(2000)"/>
            <column name="clarification_answer"   type="VARCHAR(2000)"/>
            <column name="clarification_count"    type="INT" defaultValueNumeric="0"/>
            <column name="decided_at"             type="DATETIME"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
