<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!-- One row per (visitor, day) — created in bulk when security approves a SecurityCheck -->
    <changeSet id="008-1" author="poc">
        <createTable tableName="poc_visit">
            <column name="id"                type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="security_check_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_visit_sc"
                             references="poc_security_check(id)"/>
            </column>
            <column name="visitor_id"        type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_visit_visitor"
                             references="poc_visitor(id)"/>
            </column>
            <column name="invitation_id"     type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_visit_invitation"
                             references="poc_invitation(id)"/>
            </column>
            <column name="visit_date"        type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="entrance_id"       type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_visit_entrance"
                             references="poc_entrance(id)"/>
            </column>
            <!-- PENDING | CHECKED_IN | NO_SHOW -->
            <column name="status"            type="VARCHAR(20)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="checked_in_at"     type="DATETIME"/>
            <column name="checked_in_by"     type="VARCHAR(100)"/>
        </createTable>
        <createIndex tableName="poc_visit" indexName="idx_visit_date_entrance">
            <column name="visit_date"/>
            <column name="entrance_id"/>
        </createIndex>
        <createIndex tableName="poc_visit" indexName="idx_visit_security_check">
            <column name="security_check_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
