<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!-- Round-robin assignment: which security officer is responsible for this check -->
    <changeSet id="010-1" author="poc">
        <addColumn tableName="poc_security_check">
            <column name="assigned_to" type="VARCHAR(100)"/>
        </addColumn>
        <createIndex tableName="poc_security_check" indexName="idx_sc_assigned_to">
            <column name="assigned_to"/>
        </createIndex>
    </changeSet>

    <!-- Flat two-level supervisor hierarchy for Security officers (max 10 per supervisor) -->
    <changeSet id="010-2" author="poc">
        <createTable tableName="poc_security_supervisor_assignment">
            <column name="officer_username"    type="VARCHAR(100)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="supervisor_username" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createIndex tableName="poc_security_supervisor_assignment" indexName="idx_sec_supervisor_username">
            <column name="supervisor_username"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
