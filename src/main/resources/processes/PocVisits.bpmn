      <!-- Allow Visit → Check In -->
      <bpmndi:BPMNEdge id="Flow_12x9ury_di" bpmnElement="Flow_12x9ury">
        <di:waypoint x="1150" y="400" /><di:waypoint x="1240" y="400" />
